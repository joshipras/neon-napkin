import React from 'react';
import { View, Text, StyleSheet } from 'react-native';
import MapView, { PROVIDER_GOOGLE, Marker, Callout } from 'react-native-maps';
import openMics from './data/open_mics.json';

const NY_CENTER = { latitude: 40.7128, longitude: -74.0060, latitudeDelta: 0.3, longitudeDelta: 0.3 };

function getWeekdayName(date: Date) {
  return ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'][date.getDay()];
}

export default function MapScreen() {
  const today = new Date();
  const weekday = getWeekdayName(today);
  const todaysMics = (openMics as any[]).filter(m => m.active && m.days.includes(weekday));

  return (
    <View style={styles.container}>
      <MapView
        provider={PROVIDER_GOOGLE}
        style={styles.map}
        initialRegion={NY_CENTER}
        showsUserLocation={true}
      >
        {todaysMics.map(mic => (
          <Marker
            key={mic.id}
            coordinate={{ latitude: mic.coordinates.lat, longitude: mic.coordinates.lng }}
          >
            <Callout>
              <View style={{ width: 220 }}>
                <Text style={{ fontWeight: 'bold' }}>{mic.venueName}</Text>
                <Text>{mic.venueAddress}</Text>
                <Text>{mic.signUpTimes.map((s:any)=>s.start).join(', ')} ({mic.signUpTimes[0]?.timezone})</Text>
                <Text numberOfLines={3}>{mic.signupDetails}</Text>
              </View>
            </Callout>
          </Marker>
        ))}
      </MapView>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1 },
  map: { flex: 1 }
});
